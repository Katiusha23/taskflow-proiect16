# Copiaza acest fisier in .env si completeaza valorile

# Cheia secreta pentru semnarea JWT (schimba in productie!)
JWT_SECRET=todo_secret_key_schimba_in_productie

# URL-ul frontend-ului deployat pe Vercel (pentru CORS)
FRONTEND_URL=https://<numele-tau-app>.vercel.app

# Portul serverului Express (Render il seteaza automat)
PORT=5001
