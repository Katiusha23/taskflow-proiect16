{
  "name": "todo-app-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"nodemon server.js\" \"json-server --watch db.json --port 3001\"",
    "start": "concurrently \"node server.js\" \"json-server --watch db.json --port 3001\"",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "json-server": "^0.17.4",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
